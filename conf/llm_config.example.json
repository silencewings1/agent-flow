{
  "_comment": "每节点 LLM 配置示例。复制为 llm_config.json 并按需修改。",
  "_comment2": "API Key 不写这里，改为设置对应环境变量（见 api_key_env）。",
  "_comment3": "providers.models 列表声明可用模型，model 由 node 的 provider 对象直接指定。",
  "_comment4": "base_url 使用 SDK 格式（不含 endpoint 路径，SDK 自行拼接）。",
  
  "providers": {
    "anthropic": {
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "models": [
        "claude-sonnet-4-20250514",
        "claude-opus-4-20250514"
      ],
      "protocol": "anthropic"
    },
    "openai_chat": {
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "models": [
        "gpt-4o",
        "gpt-4o-mini"
      ],
      "protocol": "openai/chat"
    },
    "openai_response": {
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "models": [
        "gpt-4o",
        "gpt-4o-mini"
      ],
      "protocol": "openai/response"
    }
  },
  
  "nodes": {
    "planner": {
      "provider": {
        "name": "anthropic",
        "model": "claude-sonnet-4-20250514"
      },
      "prompt": "分析以下需求，输出 JSON 格式的计划。"
    },
    "coder": {
      "provider": {
        "name": "openai_chat",
        "model": "gpt-4o"
      }
    },
    "debugger": {
      "provider": {
        "name": "openai_chat",
        "model": "gpt-4o"
      }
    },
    "reviewer": {
      "provider": {
        "name": "openai_chat",
        "model": "gpt-4o"
      }
    }
  }
}